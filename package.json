{
  "name": "citywatch",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "cd backend && source venv/bin/activate && uvicorn main:app --reload --port 8000",
    "dev": "concurrently \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "build": "pnpm --filter frontend build",
    "lint": "pnpm --filter frontend lint",
    "migrate": "cd scripts && python3 migrate.py",
    "seed": "cd backend/scripts && python3 seed_data.py",
    "seed:tempe": "cd backend/scripts && python3 seed_tempe.py",
    "scrape": "cd backend/scripts && python3 seed_tinyfish.py",
    "scrape:police": "cd backend/scripts && python3 scrape_police.py",
    "scrape:news": "cd backend/scripts && python3 scrape_news.py"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
